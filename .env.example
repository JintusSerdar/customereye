# Environment variables for production deployment
# Copy this file and fill in the actual values in Vercel dashboard

# Database (PostgreSQL) - Use a production database service
DATABASE_URL="postgresql://username:password@host:port/database?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="your-production-secret-here"
NEXTAUTH_URL="https://demo.customereye.ai"

# API URL for production
NEXT_PUBLIC_API_URL="https://demo.customereye.ai"

# AWS Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-west-1
AWS_BUCKET_NAME=customereye

# Database Configuration (if needed separately)
DB_HOST=your_production_db_host
DB_PORT=5432
DB_NAME=customereye
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
